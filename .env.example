# AWS Configuration (Optional - app works with localStorage if not configured)
REACT_APP_AWS_REGION=us-east-1
REACT_APP_AWS_ACCESS_KEY_ID=your_access_key_here
REACT_APP_AWS_SECRET_ACCESS_KEY=your_secret_key_here
REACT_APP_DYNAMODB_TABLE=ExpenseTracker
REACT_APP_IDENTITY_POOL_ID=your_identity_pool_id_here

# Note: For production, use Cognito Identity Pool instead of access keys
# The app will fallback to localStorage if AWS credentials are not provided